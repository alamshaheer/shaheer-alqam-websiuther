// ─── Editable Text Component ───
function Editable({ text, tag = "span", className = "", style = {}, editMode }) {
  const [value, setValue] = useState(text);
  const ref = useRef(null);

  useEffect(() => { setValue(text); }, [text]);

  const Tag = tag;
  if (!editMode) {
    return <Tag className={className} style={style}>{value}</Tag>;
  }
  return (
    <Tag
      ref={ref}
      className={className}
      style={{
        ...style,
        outline: "2px dashed rgba(255,140,0,0.5)",
        outlineOffset: "3px",
        cursor: "text",
        borderRadius: "4px",
        minWidth: "20px",
        minHeight: "1em",
      }}
      contentEditable
      suppressContentEditableWarning
      onBlur={(e) => setValue(e.target.innerText)}
    >
      {value}
    </Tag>
  );
}

